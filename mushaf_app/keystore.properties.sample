# Copy this file to `keystore.properties` and fill in your own signing-key details.
# `keystore.properties` and the *.jks key file are gitignored — never commit them.
# Without this file the project still builds a DEBUG apk; only `assembleRelease` needs it.
storeFile=release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
